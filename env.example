NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# These Google credentials are for the custom Gmail mailbox connect flow under /api/gmail/*.
# They are separate from Google sign-in through Supabase Auth.
# Optional fixed fallback. The app will derive /api/gmail/callback from the current host by default.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/callback
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3000/api/mailboxes/callback/outlook

# Hubspot Oauth 
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret
HUBSPOT_OAUTH_REDIRECT_URI=http://localhost:3000/api/crm/callback/hubspot

# Salesforce Oauth

SALESFORCE_CLIENT_ID=your-salesforce-client-id
SALESFORCE_CLIENT_SECRET=your-salesforce-client-secret
SALESFORCE_OAUTH_REDIRECT_URI=http://localhost:3000/api/crm/callback/salesforce
SALESFORCE_AUTH_BASE_URL=https://login.salesforce.com

# Pipedrive Oauth

PIPEDRIVE_CLIENT_ID=your-pipedrive-client-id
PIPEDRIVE_CLIENT_SECRET=your-pipedrive-client-secret
PIPEDRIVE_OAUTH_REDIRECT_URI=http://localhost:3000/api/crm/callback/pipedrive

# Zoho Oauth

ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_OAUTH_REDIRECT_URI=http://localhost:3000/api/crm/callback/zoho
ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.com
ZOHO_API_BASE_URL=https://www.zohoapis.com/crm/v8

# Slack Oauth

SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/slack/callback

# Calendly Oauth

CALENDLY_CLIENT_ID=your-calendly-client-id
CALENDLY_CLIENT_SECRET=your-calendly-client-secret
CALENDLY_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/calendly/callback

#Token

TOKEN_ENCRYPTION_KEY=replace-with-a-64-char-secret
CUSTOM_CRM_API_KEYS=
DEFAULT_PER_USER_DAILY_CAP=50
DEFAULT_PER_MINUTE_THROTTLE=10
FOLLOW_UP_DELAY_DAYS=2
SEED_MONITOR_INTERVAL_MINUTES=30
SUPABASE_CRON_VERIFY_SECRET=replace-with-cron-secret
ENABLE_DEMO_SEED=true
SHARED_WORKSPACE_NAME=OutboundFlow Team
SHARED_WORKSPACE_SLUG=outboundflow-team

# Redis Cache + Upstash + Vercel

USE_REDIS_CACHE=false
REDIS_CACHE_MODE=shadow
REDIS_CACHE_PREFIX=outboundflow:v1
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
